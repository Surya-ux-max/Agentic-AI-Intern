# ============================================================================
# PACKAGE MANAGERS AND DEPENDENCIES
# ============================================================================

# pip
pip-log.txt
pip-delete-this-directory.txt

# pipenv
Pipfile.lock

# poetry
poetry.lock

# conda
.conda/
conda-meta/

# ============================================================================
# CLOUD AND DEPLOYMENT
# ============================================================================

# Docker
.dockerignore
Dockerfile.prod
docker-compose.override.yml
.docker/

# Kubernetes
*.kubeconfig
kube-config

# Terraform
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# AWS
.aws/
aws-credentials

# Google Cloud
gcloud-credentials.json
service-account.json

# Azure
.azure/

# ============================================================================
# MONITORING AND ANALYTICS
# ============================================================================

# Application logs
*.log
logs/
log/

# Performance monitoring
.profiling/
*.prof

# Error tracking
.sentry-dsn
sentry.properties

# ============================================================================
# CUSTOM PROJECT EXCLUSIONS
# ============================================================================

# VijayGPT specific
user_conversations/
chat_history/
user_data/
analytics/
feedback/

# Backup files
backup/
backups/
*.backup

# Test outputs
test_outputs/
test_results/

# ============================================================================
# WHITELIST EXCEPTIONS (Files to include despite patterns above)
# ============================================================================

# Include example/template files
!example.env
!template.config
!sample_data.json
!README.md
!requirements.txt
!setup.py
!app.py

# Include documentation
!docs/
!*.md
!*.rst
!*.txt

# Include source code
!src/
!*.py
!*.js
!*.html
!*.css