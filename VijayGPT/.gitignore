# ============================================================================

# Large Model Files
*.model
*.bin
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.sav
models/
checkpoints/
weights/

# Training Data and Datasets
data/
datasets/
training_data/
test_data/
*.csv
*.tsv
*.json
*.jsonl
*.parquet
*.feather
*.arrow

# Model Outputs and Logs
logs/
outputs/
results/
experiments/
runs/
tensorboard_logs/
wandb/
mlruns/

# ============================================================================
# DEVELOPMENT AND TESTING
# ============================================================================

# Testing
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
htmlcov/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject

# ============================================================================
# SYSTEM AND OS FILES
# ============================================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============================================================================
# TEMPORARY AND CACHE FILES
# ============================================================================

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.rej
*.swp
*.swo

# Cache directories
.cache/
cache/
tmp/
temp/

