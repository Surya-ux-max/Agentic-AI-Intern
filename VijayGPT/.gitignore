# VijayGPT - High Security .gitignore

# ============================================================================
# SECURITY CRITICAL - NEVER COMMIT THESE FILES
# ============================================================================

# API Keys and Secrets
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*_rsa
*_dsa
*_ecdsa
*_ed25519
.env
.env.*
!.env.example
config.json
secrets.json
credentials.json
auth.json
token.json
*.token
*.secret
*.credentials

# Database Files (may contain sensitive data)
*.db
*.sqlite
*.sqlite3
*.db3
*.s3db
*.sl3

# Configuration Files with Potential Secrets
config.ini
config.cfg
settings.ini
local_settings.py
production_settings.py
.secrets
.credentials

# ============================================================================
# PYTHON ENVIRONMENT AND DEPENDENCIES
# ============================================================================

# Virtual Environment (vijay folder is a venv)
vijay/
venv/
env/
ENV/
.venv/
.env/
env.bak/
venv.bak/

# Python Cache and Compiled Files
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# ============================================================================
